# 阿里云 DashScope API Key
# 申请地址：https://bailian.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 运行环境：development / production
ENV=development

# 可选：切换模型（默认 qwen3.5-omni-flash）
# MODEL_NAME=qwen3.5-omni-flash
# 北京地域：https://dashscope.aliyuncs.com/compatible-mode/v1
# 新加坡地域：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：纯文本整体分析模型
# CONTINUITY_MODEL_NAME=qwen-max
# 可选：自定义 prompt/字段配置 JSON 路径；留空使用 backend/prompt_configs/default.json
# PROMPT_CONFIG_PATH=backend/prompt_configs/default.json
# 模型最短视频输入要求，短镜头会自动扩展上下文
# MIN_MODEL_VIDEO_DURATION=2.0

# 镜头检测灵敏度（10-40，越低越敏感，默认27）
# SCENE_THRESHOLD=27

# AI 分析并发数（默认2，API 有限流时降低）
# AI_CONCURRENCY=2

# 单个上传文件最大体积（MB，默认1024）
# MAX_UPLOAD_SIZE_MB=1024
# 前端上传提示/预校验大小（MB），建议与 MAX_UPLOAD_SIZE_MB 保持一致
# VITE_MAX_UPLOAD_SIZE_MB=1024
# Docker 前端 Nginx 请求体限制，建议与 MAX_UPLOAD_SIZE_MB 保持一致
# NGINX_CLIENT_MAX_BODY_SIZE=1024m

# JWT 签名密钥（生产环境必须替换为随机强密码！）
SECRET_KEY=change-me-in-production-please-use-random-32-chars

# CORS 白名单，多个域名用英文逗号分隔
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 数据库连接，默认使用 backend/app.db
# DATABASE_URL=sqlite:///./app.db

# 微信开放平台（网站应用）—— 微信扫码登录必须配置
# 申请地址：https://open.weixin.qq.com/
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
# 微信授权回调地址（需在微信开放平台配置白名单）
WECHAT_CALLBACK_URL=http://localhost:8000/api/auth/wechat/callback

# 前端地址（用于微信回调后重定向）
FRONTEND_URL=http://localhost:5173

# 新用户初始积分（默认100）
# INITIAL_CREDITS=100

# Redis / RQ 任务队列
# REDIS_URL=redis://localhost:6379/0
# TASK_QUEUE_NAME=analysis
# RUN_TASKS_INLINE=true

# API 限流（每 IP 每分钟，0 表示关闭）
# RATE_LIMIT_PER_MINUTE=120

# Cookie 会话配置
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=
