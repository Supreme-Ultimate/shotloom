# 阿里云 DashScope API Key
# 申请地址：https://bailian.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 运行环境：development / production
ENV=development

# 视觉理解与专用ASR模型
# VISION_MODEL_NAME=qwen3.7-plus
# ASR_MODEL_NAME=qwen3-asr-flash-filetrans
# 北京地域：https://dashscope.aliyuncs.com/compatible-mode/v1
# 新加坡地域：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 整体分析默认复用视觉模型
# CONTINUITY_MODEL_NAME=qwen3.7-plus
# 新加坡异步ASR接口；北京地域改为 https://dashscope.aliyuncs.com/api/v1
# ASR_API_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
# ASR_POLL_INTERVAL_SECONDS=3
# ASR_POLL_TIMEOUT_SECONDS=7200
# 可选：自定义 prompt/字段配置 JSON 路径；留空使用 backend/prompt_configs/default.json
# PROMPT_CONFIG_PATH=backend/prompt_configs/default.json
# 模型最短视频输入要求；短镜头会自动合并邻近镜头形成更稳定的分析单元
# MIN_MODEL_VIDEO_DURATION=2.0
# SAFE_MODEL_VIDEO_DURATION=3.0
# SHORT_SHOT_MERGE_MAX_SHOTS=5
# MODEL_TRANSIENT_RETRIES=2
# MODEL_TRANSIENT_RETRY_DELAY=1.0

# 镜头检测灵敏度（10-40，越低越敏感，默认27）
# SCENE_THRESHOLD=27

# AI 分析并发数（默认2，API 有限流时降低）
# AI_CONCURRENCY=2

# 单个上传文件最大体积（MB，默认1024）
# MAX_UPLOAD_SIZE_MB=1024
# 单个视频最大时长（秒，默认3600=1小时）
# MAX_VIDEO_DURATION_SECONDS=3600
# 前端上传提示/预校验大小（MB），建议与 MAX_UPLOAD_SIZE_MB 保持一致
# VITE_MAX_UPLOAD_SIZE_MB=1024
# 前端上传提示时长（秒），建议与 MAX_VIDEO_DURATION_SECONDS 保持一致
# VITE_MAX_VIDEO_DURATION_SECONDS=3600
# Docker 前端 Nginx 请求体限制，建议与 MAX_UPLOAD_SIZE_MB 保持一致
# NGINX_CLIENT_MAX_BODY_SIZE=1024m

# 腾讯云 COS 浏览器分片直传（CVM 需绑定同名 CAM 角色，无需长期密钥）
# COS_UPLOAD_ENABLED=false
# COS_BUCKET=weixi-1442785787
# COS_REGION=ap-singapore
# COS_ROLE_NAME=weixi
# COS_ACCELERATE=true
# COS_PART_SIZE_MB=16
# COS_SIGNED_URL_EXPIRE_SECONDS=1800

# JWT 签名密钥（生产环境必须替换为随机强密码！）
SECRET_KEY=change-me-in-production-please-use-random-32-chars

# CORS 白名单，多个域名用英文逗号分隔
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 数据库连接，默认使用 backend/app.db
# DATABASE_URL=sqlite:///./app.db

# 微信开放平台（网站应用）—— 微信扫码登录必须配置
# 申请地址：https://open.weixin.qq.com/
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
# 微信授权回调地址（需在微信开放平台配置白名单）
WECHAT_CALLBACK_URL=http://localhost:8000/api/auth/wechat/callback

# 前端地址（用于微信回调后重定向）
FRONTEND_URL=http://localhost:5173

# 新用户初始积分（默认100）
# INITIAL_CREDITS=100

# Redis / RQ 任务队列
# REDIS_URL=redis://localhost:6379/0
# TASK_QUEUE_NAME=analysis
# RUN_TASKS_INLINE=true

# API 限流（每 IP 每分钟，0 表示关闭）
# RATE_LIMIT_PER_MINUTE=120

# Cookie 会话配置
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=


# 上下文分析路由：auto 会按整片/分块/单镜头回退自动选择
# ANALYSIS_ROUTER_MODE=auto
# 整片上下文分析上限（秒/镜头数）。本地 Base64 输入建议保持较小，长视频会自动分块。
# WHOLE_VIDEO_MAX_DURATION=180
# WHOLE_VIDEO_MAX_SHOTS=60
# 分块段落分析窗口（秒/镜头数/重叠镜头数）
# CHUNK_SEGMENT_DURATION=300
# CHUNK_SEGMENT_MAX_SHOTS=80
# CHUNK_SEGMENT_OVERLAP_SHOTS=2
# 上下文分析缺失某些镜头时，是否自动回退到单镜头/短镜头合并分析
# SHOT_FALLBACK_ENABLED=true
# OpenAI 兼容接口使用本地 Base64 传视频时的整片大小保护（MB）
# CONTEXT_BASE64_MAX_MB=8
# Qwen 视频输入模式：auto=小文件 Base64，大文件签名 URL；base64=强制 Base64；url=强制签名 URL
# QWEN_VIDEO_INPUT_MODE=auto
# 可被 Qwen 服务器公网访问的服务地址；专用ASR必须配置
# PUBLIC_VIDEO_BASE_URL=https://your-domain.example.com
# ASR专用签名URL有效期（秒）
# ASR_SIGNED_URL_EXPIRE_SECONDS=3600
# 签名视频 URL 有效期（秒）
# SIGNED_VIDEO_URL_EXPIRE_SECONDS=1800
# 签名视频 URL 独立密钥；生产环境建议设置为随机长字符串，不设置时回退 SECRET_KEY
# SIGNED_VIDEO_URL_SECRET=change_me_random_32_chars
