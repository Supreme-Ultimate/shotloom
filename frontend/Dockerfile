FROM node:20-alpine AS build
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ ./
ARG VITE_API_BASE_URL=
ARG VITE_APP_TITLE=ShotLoom
ARG VITE_MAX_UPLOAD_SIZE_MB=1024
ARG VITE_MAX_VIDEO_DURATION_SECONDS=3600
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_APP_TITLE=$VITE_APP_TITLE
ENV VITE_MAX_UPLOAD_SIZE_MB=$VITE_MAX_UPLOAD_SIZE_MB
ENV VITE_MAX_VIDEO_DURATION_SECONDS=$VITE_MAX_VIDEO_DURATION_SECONDS
RUN npm run build

FROM nginx:1.27-alpine
ENV NGINX_CLIENT_MAX_BODY_SIZE=1024m
COPY docker/nginx.conf.template /etc/nginx/templates/default.conf.template
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
